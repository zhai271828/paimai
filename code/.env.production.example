# 《拍卖师法则 Online》朋友局生产配置示例
# 复制成 .env.production 或按服务器面板方式配置环境变量。

NODE_ENV=production
HOST=0.0.0.0
PORT=3001

# 前端和后端同端口部署时，必须写你朋友访问的完整源。
# 例：公网 IP: http://12.34.56.78:3001
# 例：域名 HTTPS: https://auction.example.com
AUCTIONEER_ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# 单机朋友局推荐 SQLite。数据会落到 AUCTIONEER_SQLITE_PATH。
AUCTIONEER_REPOSITORY=sqlite
AUCTIONEER_DATA_DIR=data/rooms
AUCTIONEER_SQLITE_PATH=data/rooms/auctioneer.sqlite

# 生产服务会自动托管 apps/web/dist；如果你的目录不同，可以显式指定。
AUCTIONEER_STATIC_DIR=apps/web/dist

# 玩家掉线后自动托管，避免整局卡住。默认 45000 毫秒。
AUCTIONEER_OFFLINE_AUTOPLAY_MS=45000

# 朋友局一般不需要调大。被频繁刷新/误点限流时可临时提高。
AUCTIONEER_RATE_LIMIT_WINDOW_MS=60000
AUCTIONEER_RATE_LIMIT_MAX=240
AUCTIONEER_CREATE_ROOM_LIMIT=20
AUCTIONEER_JOIN_ROOM_LIMIT=60
AUCTIONEER_RESUME_LIMIT=120
AUCTIONEER_SOCKET_ACTION_LIMIT=80
