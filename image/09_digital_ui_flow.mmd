flowchart TD
    A["打开游戏"] --> B["主菜单"]
    B --> C["新建房间"]
    B --> D["加入房间"]
    B --> E["单机人机"]
    B --> F["教程"]

    C --> G["房间设置"]
    D --> G
    E --> G

    G --> G1["选择人数 3-6"]
    G1 --> G2["选择 AI 数量和性格"]
    G2 --> G3["选择局长：短局 6 日 / 标准 8 日 / 长局 10 日"]
    G3 --> G4["选择是否启用高级事件和赝品委托"]
    G4 --> H["进入角色选择"]

    F --> F1["交互式教学：出价、鉴定、风险、结算"]
    F1 --> H

    H --> H1["玩家选择角色"]
    H1 --> H2["抽取秘密委托"]
    H2 --> H3["确认准备"]
    H3 --> I["进入正式游戏"]

    I --> J["预展界面"]
    J --> J1["查看拍品卡"]
    J1 --> J2["查看个人现金、风险、套装进度"]
    J2 --> K["情报界面"]
    K --> K1["购买鉴定或传闻"]
    K1 --> L["竞拍界面"]
    L --> L1["举牌 / 加价 / 退出 / 表情动作"]
    L1 --> M["结算界面"]
    M --> M1["展示成交、藏品入手、风险变化"]
    M1 --> N["事件界面"]
    N --> N1["展示市场事件和下一轮变化"]
    N1 --> O{"是否终局？"}
    O -- "否" --> J
    O -- "是" --> P["终局翻牌结算"]
    P --> Q["胜者展示与回放"]
