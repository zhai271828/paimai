flowchart TD
    A["开始竞拍一件或一组拍品"] --> B{"拍卖方式"}

    B --> C["英式公开加价"]
    C --> C1["设置起拍价"]
    C1 --> C2["玩家依次选择：加价 / 跟价 / 退出"]
    C2 --> C3{"是否只剩 1 名未退出玩家？"}
    C3 -- "否" --> C2
    C3 -- "是" --> C4["最高出价者成交"]

    B --> D["暗标拍卖"]
    D --> D1["所有玩家同时秘密写下出价"]
    D1 --> D2["同时公开出价"]
    D2 --> D3{"是否有并列最高价？"}
    D3 -- "是" --> D4["并列者追加一轮暗标或按角色优先权决定"]
    D3 -- "否" --> D5["最高出价者成交"]
    D4 --> D5

    B --> E["荷兰拍卖"]
    E --> E1["价格从高位开始下降"]
    E1 --> E2{"是否有玩家喊停？"}
    E2 -- "否" --> E3["价格继续下降"]
    E3 --> E2
    E2 -- "是" --> E4["喊停玩家以当前价格成交"]

    B --> F["打包拍卖"]
    F --> F1["将 2-3 件藏品作为一组"]
    F1 --> F2["玩家按整组估值出价"]
    F2 --> F3["使用公开加价或暗标规则"]
    F3 --> F4["赢家一次性获得整组藏品"]

    B --> G["保证金拍卖"]
    G --> G1["参与者先支付保证金"]
    G1 --> G2["进行公开加价"]
    G2 --> G3{"玩家是否恶意抬价后退出？"}
    G3 -- "是" --> G4["可能损失保证金"]
    G3 -- "否" --> G5["正常成交或退出"]
    G4 --> G6["最高出价者成交"]
    G5 --> G6

    B --> H["盲盒仓库"]
    H --> H1["只公开类别、数量、传闻区间"]
    H1 --> H2["玩家低价竞拍未知包"]
    H2 --> H3["成交后翻开具体藏品"]

    C4 --> I["成交处理"]
    D5 --> I
    E4 --> I
    F4 --> I
    G6 --> I
    H3 --> I

    I --> I1["赢家支付成交价"]
    I1 --> I2{"赢家现金是否足够？"}
    I2 -- "足够" --> I3["获得藏品"]
    I2 -- "不足" --> I4["选择贷款 / 抵押 / 放弃并受罚"]
    I4 --> I5{"是否成功补足？"}
    I5 -- "是" --> I3
    I5 -- "否" --> I6["流拍或由第二高价者接手"]
    I3 --> J["进入本拍品结算"]
    I6 --> J
