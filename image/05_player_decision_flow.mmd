flowchart TD
    A["轮到玩家做关键决策"] --> B{"当前最重要的问题是什么？"}

    B --> C["我真的需要这件拍品吗？"]
    C --> C1{"是否匹配我的角色 / 套装 / 秘密委托？"}
    C1 -- "强匹配" --> C2["提高心理估值"]
    C1 -- "弱匹配" --> C3["只在低价时考虑"]
    C1 -- "不匹配" --> C4["考虑抬价或放弃"]

    B --> D["我知道的信息是否比别人多？"]
    D --> D1{"是否掌握真伪或价值线索？"}
    D1 -- "是" --> D2["利用信息差出价或误导"]
    D1 -- "否" --> D3["观察对手行为，必要时买情报"]

    B --> E["我现在现金是否安全？"]
    E --> E1{"买下后是否还有 10 银元以上？"}
    E1 -- "是" --> E2["可继续竞价"]
    E1 -- "否" --> E3["谨慎；考虑后续压轴品"]

    B --> F["别人为什么想要它？"]
    F --> F1{"对手是否明显在凑套装？"}
    F1 -- "是" --> F2["可抬价，但注意别接盘"]
    F1 -- "否" --> F3["判断是否有人掌握隐藏信息"]

    B --> G["风险是否快爆？"]
    G --> G1{"买入后风险是否达到 5 或 6？"}
    G1 -- "是" --> G2["除非收益很高，否则放弃或买保险"]
    G1 -- "否" --> G3["可承受风险"]

    C2 --> H["决定最高心理价"]
    C3 --> H
    C4 --> H
    D2 --> H
    D3 --> H
    E2 --> H
    E3 --> H
    F2 --> H
    F3 --> H
    G2 --> H
    G3 --> H

    H --> I{"当前价格是否低于最高心理价？"}
    I -- "是" --> J["继续出价 / 伪装犹豫 / 强势举牌"]
    I -- "否" --> K["退出 / 装作没兴趣 / 等下一件"]
