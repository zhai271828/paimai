flowchart TD
    A["第 8 个拍卖日结束"] --> B["进入终局结算"]

    B --> C["所有玩家公开藏品"]
    C --> C1["揭示未公开真伪"]
    C1 --> C2["揭示真实价值"]

    C2 --> D["计算现金分"]
    D --> D1["每 5 银元 = 1 声望"]

    D1 --> E["计算藏品价值分"]
    E --> E1["按真实价值换算声望或直接计入"]

    E1 --> F["计算套装奖励"]
    F --> F1{"同系列数量"}
    F1 -- "2 件" --> F2["+4 声望"]
    F1 -- "3 件" --> F3["+10 声望"]
    F1 -- "4 件及以上" --> F4["+18 声望"]
    F1 -- "不足 2 件" --> F5["无套装奖励"]

    F2 --> G["公开秘密委托"]
    F3 --> G
    F4 --> G
    F5 --> G

    G --> G1{"委托是否完成？"}
    G1 -- "完成" --> G2["获得委托声望"]
    G1 -- "失败" --> G3["无奖励或小额惩罚"]

    G2 --> H["结算风险与负面效果"]
    G3 --> H

    H --> H1["扣除贷款惩罚"]
    H1 --> H2["处理诅咒扣分"]
    H2 --> H3["处理查封 / 违禁惩罚"]
    H3 --> H4["处理未赎回抵押品"]

    H4 --> I["汇总总声望"]
    I --> J{"是否平分最高？"}
    J -- "否" --> K["总声望最高者获胜"]
    J -- "是" --> L["依次比较：现金更多 -> 藏品更多 -> 风险更低"]
    L --> K
    K --> M["展示终局故事：最大捡漏、最惨接盘、最佳抬价"]
