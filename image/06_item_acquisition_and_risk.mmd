flowchart TD
    A["玩家拍下藏品"] --> B["支付成交价"]
    B --> C["获得藏品卡"]
    C --> D{"是否立即公开真伪？"}
    D -- "公开" --> D1["全场知道真实结果"]
    D -- "不公开" --> D2["只有拥有者或鉴定者知道"]

    D1 --> E["检查藏品标签"]
    D2 --> E

    E --> F{"是否有违禁标签？"}
    F -- "是" --> F1["持有者风险 +1"]
    F -- "否" --> G
    F1 --> G

    G{"是否有诅咒标签？"} -- "是" --> G1["记录诅咒效果"]
    G -- "否" --> H
    G1 --> H

    H{"是否有易碎 / 保管标签？"} -- "是" --> H1["支付保管费或承受损坏风险"]
    H -- "否" --> I
    H1 --> I

    I{"是否触发角色能力？"} -- "是" --> I1["执行角色能力"]
    I -- "否" --> J
    I1 --> J

    J{"是否形成套装？"} -- "是" --> J1["记录套装进度与潜在奖励"]
    J -- "否" --> K
    J1 --> K

    K{"现金是否低于危险线？"} -- "是" --> K1["可选择贷款、抵押、出售"]
    K -- "否" --> L["本件藏品结算完成"]
    K1 --> K2{"是否贷款？"}
    K2 -- "是" --> K3["获得 15 银元，终局扣 20 银元等值"]
    K2 -- "否" --> K4{"是否抵押藏品？"}
    K4 -- "是" --> K5["获得估值下限一半现金，之后可赎回"]
    K4 -- "否" --> L
    K3 --> L
    K5 --> L
