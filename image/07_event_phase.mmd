flowchart TD
    A["拍卖日结算后"] --> B["翻开 1 张事件牌"]
    B --> C{"事件影响对象"}

    C --> D["市场价格"]
    D --> D1["某类别最终价值上升或下降"]
    D1 --> D2["玩家重新评估手中藏品和未来目标"]

    C --> E["风险清查"]
    E --> E1["检查风险最高玩家"]
    E1 --> E2{"风险是否达到清查阈值？"}
    E2 -- "是" --> E3["封存、罚款或扣声望"]
    E2 -- "否" --> E4["仅警告或无事发生"]

    C --> F["现金流"]
    F --> F1["贷款成本变化 / 不能贷款 / 出售价格变化"]
    F1 --> F2["现金紧张玩家被迫调整策略"]

    C --> G["信息公开"]
    G --> G1["免费获得半公开信息或重鉴机会"]
    G1 --> G2["全场讨论和误导升级"]

    C --> H["拍卖规则"]
    H --> H1["下一轮改为暗标 / 荷兰拍 / 保证金拍卖"]
    H1 --> H2["玩家改变现金和出价策略"]

    D2 --> I["事件效果记录到公共区域"]
    E3 --> I
    E4 --> I
    F2 --> I
    G2 --> I
    H2 --> I

    I --> J["检查是否有角色或藏品响应事件"]
    J --> K["移动起始玩家"]
    K --> L["进入下一个拍卖日"]
