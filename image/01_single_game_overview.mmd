flowchart TD
    A["开始游戏"] --> B["选择模式"]
    B --> B1["桌游 / 本地多人"]
    B --> B2["数字版人机 / 联机房间"]

    B1 --> C["玩家准备"]
    B2 --> C

    C --> C1["每位玩家选择或随机获得 1 张角色卡"]
    C1 --> C2["每位玩家获得 45 银元"]
    C2 --> C3["每位玩家风险值归零"]
    C3 --> C4["每位玩家抽 2 张秘密委托，保留 1 张"]
    C4 --> C5["洗混藏品牌、事件牌、拍卖方式牌"]
    C5 --> C6["设置起始玩家"]

    C6 --> D["进入拍卖日循环"]
    D --> E{"是否已完成 8 个拍卖日？"}
    E -- "否" --> F["执行一个拍卖日"]
    F --> G["拍卖日计数 +1"]
    G --> E
    E -- "是" --> H["终局揭示与结算"]

    H --> H1["揭示所有未公开真伪与真实价值"]
    H1 --> H2["计算剩余现金分"]
    H2 --> H3["计算藏品真实价值分"]
    H3 --> H4["计算系列套装奖励"]
    H4 --> H5["公开并结算秘密委托"]
    H5 --> H6["结算贷款、风险、诅咒、查封惩罚"]
    H6 --> I{"谁的声望最高？"}
    I --> J["最高声望玩家获胜"]
    J --> K["展示关键回合回放 / 复盘谁抬价成功"]
