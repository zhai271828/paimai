flowchart TD
    A["玩家进入情报阶段"] --> B{"玩家是否愿意花钱获取信息？"}
    B -- "否" --> Z["保留现金，进入等待"]
    B -- "是" --> C{"选择哪种情报？"}

    C --> C1["粗鉴：花 1 银元"]
    C1 --> C1A["查看目标藏品价值偏高 / 偏低"]
    C1A --> C1B["信息仅自己知道"]

    C --> C2["细鉴：花 3 银元"]
    C2 --> C2A["查看目标藏品真伪"]
    C2A --> C2B["不能强制证明给他人"]

    C --> C3["专家证书：花 5 银元"]
    C3 --> C3A["查看真伪并获得证书"]
    C3A --> C3B["出售或结算时获得额外收益"]

    C --> C4["黑市耳语：花 2 银元"]
    C4 --> C4A["查看一名对手是否拥有某系列藏品"]
    C4A --> C4B["用于判断对手是否会抢关键件"]

    C --> C5["未来线索：花 2 银元"]
    C5 --> C5A["查看未来 1-2 轮可能出现的类别或事件倾向"]
    C5A --> C5B["用于决定本轮是否省钱"]

    C1B --> D{"是否公开宣称？"}
    C2B --> D
    C3B --> D
    C4B --> D
    C5B --> D

    D -- "沉默" --> E["形成隐藏信息优势"]
    D -- "说真话" --> F["影响全场估值"]
    D -- "撒谎 / 半真半假" --> G["诱导对手抬价或放弃"]

    E --> H["进入竞拍阶段"]
    F --> H
    G --> H
